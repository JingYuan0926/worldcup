# ── Exact Match environment ────────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit `.env`. See README §7.

# Which TxLINE network the app/services target for DATA: "devnet" | "mainnet"
TXLINE_NETWORK=devnet

# Solana RPC endpoints (override defaults if you have a private RPC)
SOLANA_DEVNET_RPC=https://api.devnet.solana.com
SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Browser-side RPC used by the web wallet provider (public endpoint only).
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Wallet used to sign the on-chain `subscribe` tx and (later) app txs.
# Path to a Solana keypair JSON (array of 64 bytes). Generated by `npm run auth` if absent.
DEVNET_WALLET_KEYPAIR=./keypairs/devnet.json
MAINNET_WALLET_KEYPAIR=./keypairs/mainnet.json

# Service level for subscribe(): devnet=1 (free, 0s delay); mainnet=12 (free, real-time).
DEVNET_SERVICE_LEVEL=1
MAINNET_SERVICE_LEVEL=12
# subscribe() weeks arg must be a multiple of 4
SUBSCRIBE_WEEKS=4

# Persisted TxLINE tokens are written here per-network by the auth module (gitignored).
TXLINE_TOKENS_DIR=./.tokens

# Known fixtures (README §7.7)
WC_QF_FIXTURE_ID=18209181
