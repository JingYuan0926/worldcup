# secrets & wallets
.env
.env.*
!.env.example
*.keypair.json
keypairs/
.tokens/

# Recordings: commit the captured TxLINE data (scores/odds/timeline + meta) so the
# submission shows real feed usage, but never the operational logs, daemon state,
# lockfiles, or per-stream cursors.
recordings/*
!recordings/.gitignore
!recordings/sample/
!recordings/sample/**
!recordings/devnet/
recordings/devnet/*
!recordings/devnet/*/
recordings/devnet/*/*
!recordings/devnet/*/*.ndjson
!recordings/devnet/*/*.manifest.json
!recordings/devnet/*/meta.json

# deps & build
node_modules/
dist/
.next/
.next-build/
out/
target/
*.tsbuildinfo
coverage/
.turbo/
.cache/
.vercel/

# misc
.DS_Store
*.log
*.pid
*.swp

# local development-agent state
.claude/settings.local.json
.agents/
.codex/

# installed macOS service (contains machine-specific absolute paths)
services/ingest/launchd/com.exactmatch.txline-auto-record.plist

# frontend (derek merge): generated + demo/runtime artifacts
next-env.d.ts
.usdc-mint.json
.demo-state.json
public/game.mov
program/.anchor/
